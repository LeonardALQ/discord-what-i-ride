# Copy this file to ".env" and fill in your values.

# Required: your Discord bot token (Developer Portal > your app > Bot > Reset Token)
DISCORD_TOKEN=your-bot-token-here

# Recommended: your server (guild) ID. Slash-command changes appear instantly
# when scoped to a guild; global sync can take up to ~1 hour.
GUILD_ID=

# --- Garage datastore (a private channel; no local files) -----------------
# Leave GARAGE_CHANNEL_ID blank to let the bot auto-create a private channel
# named GARAGE_CHANNEL_NAME (requires the "Manage Channels" permission once).
# Or create the channel yourself, make it private, and paste its ID here.
GARAGE_CHANNEL_ID=
GARAGE_CHANNEL_NAME=garage-archive

# --- Optional make-level role (off by default) ----------------------------
# If true, also gives riders a role for their bike's manufacturer (needs
# "Manage Roles"). The garage channel is the primary store regardless.
ENABLE_MAKE_ROLE=false
ROLE_PREFIX=

# Minimum confidence (0-100) before a match is shown as "confident".
MIN_CONFIDENCE=55

# Optional: only used by data/fetch_dataset.py to expand the dataset.
API_NINJAS_KEY=
